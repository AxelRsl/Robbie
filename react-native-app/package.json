{
  "name": "xiabao-retail-app",
  "version": "1.0.0",
  "description": "Aplicación React Native para robot Xiabao con modos Minorista y Promoción",
  "main": "index.js",
  "scripts": {
    "start": "react-native start",
    "android": "react-native run-android",
    "bundle:android": "react-native bundle --platform android --dev false --entry-file index.js --bundle-output ../app/src/main/assets/platform.android.bundle --assets-dest ../app/src/main/res",
    "bundle:release": "react-native bundle --platform android --dev false --entry-file index.js --bundle-output ./build/platform.android.bundle --assets-dest ./build/assets",
    "test": "jest",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx"
  },
  "dependencies": {
    "@react-navigation/bottom-tabs": "^6.5.7",
    "@react-navigation/native": "^6.1.6",
    "@react-navigation/stack": "^6.3.16",
    "axios": "^1.4.0",
    "react": "18.2.0",
    "react-native": "0.71.8",
    "react-native-gesture-handler": "^2.9.0",
    "react-native-reanimated": "^2.14.4",
    "react-native-safe-area-context": "^4.5.0",
    "react-native-screens": "^3.20.0",
    "react-native-vector-icons": "^9.2.0",
    "react-native-video": "^5.2.1",
    "zustand": "^4.3.8"
  },
  "devDependencies": {
    "@babel/core": "^7.20.0",
    "@babel/preset-env": "^7.20.0",
    "@babel/runtime": "^7.20.0",
    "@react-native-community/eslint-config": "^3.2.0",
    "@react-native/metro-config": "^0.85.0",
    "@tsconfig/react-native": "^2.0.2",
    "@types/react": "^18.0.24",
    "@types/react-native": "^0.71.0",
    "@typescript-eslint/eslint-plugin": "^5.37.0",
    "@typescript-eslint/parser": "^5.37.0",
    "babel-jest": "^29.2.1",
    "babel-plugin-module-resolver": "^5.0.3",
    "eslint": "^8.19.0",
    "jest": "^29.2.1",
    "metro-react-native-babel-preset": "0.73.9",
    "prettier": "^2.4.1",
    "typescript": "4.8.4"
  },
  "engines": {
    "node": ">=16"
  }
}
