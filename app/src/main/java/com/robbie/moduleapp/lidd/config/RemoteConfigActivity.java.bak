package com.robbie.moduleapp.lidd.config;

import android.os.Bundle;
import android.view.LayoutInflater;
import android.view.View;
import android.widget.ArrayAdapter;
import android.widget.Button;
import android.widget.EditText;
import android.widget.LinearLayout;
import android.widget.Spinner;
import android.widget.TextView;
import android.widget.Toast;

import androidx.appcompat.app.AlertDialog;
import androidx.appcompat.app.AppCompatActivity;

import com.robbie.base.config.RemoteConfigManager;

/**
 * Activity para editar la configuracion de conexiones remotas.
 *
 * Permite modificar en tiempo de ejecucion todos los dominios, credenciales y endpoints
 * que en el proyecto xiabao original estan hardcodeados en Constants y CosManager.
 * Los cambios se persisten en SharedPreferences a traves de RemoteConfigManager.
 */
public class RemoteConfigActivity extends AppCompatActivity {

    private RemoteConfigManager mConfig;
    private LinearLayout mContainer;
    private Spinner mSpinnerRegion;

    private static final String[] REGIONS = {
            RemoteConfigManager.REGION_GLOBAL,
            RemoteConfigManager.REGION_US,
            RemoteConfigManager.REGION_JP,
            RemoteConfigManager.REGION_CN_PROD,
            RemoteConfigManager.REGION_CN_TEST,
            RemoteConfigManager.REGION_CN_DEV
    };

    private static final String[] REGION_LABELS = {
            "Global",
            "USA",
            "Japon",
            "China (Produccion)",
            "China (Testing)",
            "China (Desarrollo)"
    };

    @Override
    protected void onCreate(Bundle savedInstanceState) {
        super.onCreate(savedInstanceState);
        setContentView(R.layout.activity_remote_config);

        mConfig = RemoteConfigManager.getInstance();
        mContainer = findViewById(R.id.config_container);
        mSpinnerRegion = findViewById(R.id.spinner_region);
        Button btnSave = findViewById(R.id.btn_save);
        Button btnReset = findViewById(R.id.btn_reset);

        setupRegionSpinner();
        buildConfigFields();

        btnSave.setOnClickListener(v -> saveAll());
        btnReset.setOnClickListener(v -> confirmReset());
    }

    private void setupRegionSpinner() {
        ArrayAdapter<String> adapter = new ArrayAdapter<>(
                this, android.R.layout.simple_spinner_item, REGION_LABELS);
        adapter.setDropDownViewResource(android.R.layout.simple_spinner_dropdown_item);
        mSpinnerRegion.setAdapter(adapter);

        String current = mConfig.getActiveRegion();
        for (int i = 0; i < REGIONS.length; i++) {
            if (REGIONS[i].equals(current)) {
                mSpinnerRegion.setSelection(i);
                break;
            }
        }
    }

    private void buildConfigFields() {
        mContainer.removeAllViews();

        addSection("Dominios API OrionBase");
        addField(RemoteConfigManager.KEY_SERVER_DOMAIN_GLOBAL,
                "Global", RemoteConfigManager.DEFAULT_SERVER_DOMAIN_GLOBAL);
        addField(RemoteConfigManager.KEY_SERVER_DOMAIN_US,
                "USA", RemoteConfigManager.DEFAULT_SERVER_DOMAIN_US);
        addField(RemoteConfigManager.KEY_SERVER_DOMAIN_JP,
                "Japon", RemoteConfigManager.DEFAULT_SERVER_DOMAIN_JP);
        addField(RemoteConfigManager.KEY_SERVER_DOMAIN_CN_PROD,
                "China Prod", RemoteConfigManager.DEFAULT_SERVER_DOMAIN_CN_PROD);
        addField(RemoteConfigManager.KEY_SERVER_DOMAIN_CN_TEST,
                "China Test", RemoteConfigManager.DEFAULT_SERVER_DOMAIN_CN_TEST);
        addField(RemoteConfigManager.KEY_SERVER_DOMAIN_CN_DEV,
                "China Dev", RemoteConfigManager.DEFAULT_SERVER_DOMAIN_CN_DEV);

        addSection("Dominios BI / Telemetria");
        addField(RemoteConfigManager.KEY_BI_DOMAIN_GLOBAL,
                "Global", RemoteConfigManager.DEFAULT_BI_DOMAIN_GLOBAL);
        addField(RemoteConfigManager.KEY_BI_DOMAIN_US,
                "USA", RemoteConfigManager.DEFAULT_BI_DOMAIN_US);
        addField(RemoteConfigManager.KEY_BI_DOMAIN_JP,
                "Japon", RemoteConfigManager.DEFAULT_BI_DOMAIN_JP);
        addField(RemoteConfigManager.KEY_BI_DOMAIN_CN_PROD,
                "China Prod", RemoteConfigManager.DEFAULT_BI_DOMAIN_CN_PROD);
        addField(RemoteConfigManager.KEY_BI_DOMAIN_CN_TEST,
                "China Test", RemoteConfigManager.DEFAULT_BI_DOMAIN_CN_TEST);
        addField(RemoteConfigManager.KEY_BI_DOMAIN_CN_DEV,
                "China Dev", RemoteConfigManager.DEFAULT_BI_DOMAIN_CN_DEV);

        addSection("AI Open (Autenticacion OAuth2)");
        addField(RemoteConfigManager.KEY_AI_OPEN_PROD,
                "Produccion", RemoteConfigManager.DEFAULT_AI_OPEN_PROD);
        addField(RemoteConfigManager.KEY_AI_OPEN_TEST,
                "Testing", RemoteConfigManager.DEFAULT_AI_OPEN_TEST);

        addSection("Credenciales de Aplicacion");
        addField(RemoteConfigManager.KEY_APP_ID,
                "App ID", RemoteConfigManager.DEFAULT_APP_ID);
        addField(RemoteConfigManager.KEY_APP_SECRET,
                "App Secret", RemoteConfigManager.DEFAULT_APP_SECRET);
        addField(RemoteConfigManager.KEY_CLIENT_ID,
                "Client ID", RemoteConfigManager.DEFAULT_CLIENT_ID);

        addSection("Portal AgentPOI");
        addField(RemoteConfigManager.KEY_AGENTPOI_PROD,
                "Produccion", RemoteConfigManager.DEFAULT_AGENTPOI_PROD);
        addField(RemoteConfigManager.KEY_AGENTPOI_TEST,
                "Testing", RemoteConfigManager.DEFAULT_AGENTPOI_TEST);

        addSection("Otros Servicios");
        addField(RemoteConfigManager.KEY_JIEDAI_URL,
                "Portal Jiedai", RemoteConfigManager.DEFAULT_JIEDAI_URL);
        addField(RemoteConfigManager.KEY_BAIDU_API_KEY,
                "Baidu Maps API Key", RemoteConfigManager.DEFAULT_BAIDU_API_KEY);

        addSection("Endpoints REST (paths relativos)");
        addField(RemoteConfigManager.KEY_ENDPOINT_APPS_PAGE,
                "Apps Page", RemoteConfigManager.DEFAULT_ENDPOINT_APPS_PAGE);
        addField(RemoteConfigManager.KEY_ENDPOINT_APPS_VERSION,
                "Apps Version", RemoteConfigManager.DEFAULT_ENDPOINT_APPS_VERSION);
        addField(RemoteConfigManager.KEY_ENDPOINT_GET_CORE_JS,
                "Core JS", RemoteConfigManager.DEFAULT_ENDPOINT_GET_CORE_JS);
        addField(RemoteConfigManager.KEY_ENDPOINT_CRASH_UPLOAD,
                "Crash Upload", RemoteConfigManager.DEFAULT_ENDPOINT_CRASH_UPLOAD);
        addField(RemoteConfigManager.KEY_ENDPOINT_ANR_UPLOAD,
                "ANR Upload", RemoteConfigManager.DEFAULT_ENDPOINT_ANR_UPLOAD);
        addField(RemoteConfigManager.KEY_ENDPOINT_BI_POST,
                "BI Post", RemoteConfigManager.DEFAULT_ENDPOINT_BI_POST);
        addField(RemoteConfigManager.KEY_ENDPOINT_TOKEN,
                "Token", RemoteConfigManager.DEFAULT_ENDPOINT_TOKEN);
        addField(RemoteConfigManager.KEY_ENDPOINT_COS_SECRET,
                "COS Secret", RemoteConfigManager.DEFAULT_ENDPOINT_COS_SECRET);

        addSection("MQTT");
        addField(RemoteConfigManager.KEY_MQTT_BROKER_URL,
                "Broker URL", RemoteConfigManager.DEFAULT_MQTT_BROKER_URL);
        addField(RemoteConfigManager.KEY_MQTT_TOPIC_ROOT,
                "Topic Root", RemoteConfigManager.DEFAULT_MQTT_TOPIC_ROOT);
    }

    private void addSection(String title) {
        View sectionView = LayoutInflater.from(this)
                .inflate(R.layout.item_config_section, mContainer, false);
        TextView tvTitle = sectionView.findViewById(R.id.tv_section_title);
        tvTitle.setText(title);
        mContainer.addView(sectionView);
    }

    private void addField(String key, String label, String defaultValue) {
        View fieldView = LayoutInflater.from(this)
                .inflate(R.layout.item_config_field, mContainer, false);

        TextView tvLabel = fieldView.findViewById(R.id.tv_field_label);
        EditText etValue = fieldView.findViewById(R.id.et_field_value);

        tvLabel.setText(label);

        String currentValue = mConfig.getString(key, defaultValue);
        etValue.setText(currentValue);
        etValue.setHint(defaultValue);
        etValue.setTag(key);

        mContainer.addView(fieldView);
    }

    private void saveAll() {
        int selectedRegion = mSpinnerRegion.getSelectedItemPosition();
        if (selectedRegion >= 0 && selectedRegion < REGIONS.length) {
            mConfig.setActiveRegion(REGIONS[selectedRegion]);
        }

        for (int i = 0; i < mContainer.getChildCount(); i++) {
            View child = mContainer.getChildAt(i);
            EditText et = child.findViewById(R.id.et_field_value);
            if (et != null && et.getTag() != null) {
                String key = (String) et.getTag();
                String value = et.getText().toString().trim();
                mConfig.putString(key, value);
            }
        }

        mConfig.logCurrentConfig();
        Toast.makeText(this, "Configuracion guardada", Toast.LENGTH_SHORT).show();
        finish();
    }

    private void confirmReset() {
        new AlertDialog.Builder(this)
                .setTitle("Restaurar valores por defecto")
                .setMessage("Se restauraran todos los valores a los originales de OrionStar. Esta accion no se puede deshacer.")
                .setPositiveButton("Restaurar", (dialog, which) -> {
                    mConfig.resetToDefaults();
                    Toast.makeText(this, "Valores restaurados", Toast.LENGTH_SHORT).show();
                    setupRegionSpinner();
                    buildConfigFields();
                })
                .setNegativeButton("Cancelar", null)
                .show();
    }
}
