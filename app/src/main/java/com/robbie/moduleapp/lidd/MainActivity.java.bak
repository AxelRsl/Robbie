package com.robbie.moduleapp.lidd;

import android.content.Intent;
import android.os.Bundle;
import android.widget.Button;
import android.widget.TextView;

import androidx.appcompat.app.AppCompatActivity;

import com.robbie.base.config.RemoteConfigManager;
import com.robbie.moduleapp.lidd.config.RemoteConfigActivity;

/**
 * Activity principal de xiabao_lidd.
 *
 * Muestra un resumen de la configuracion remota activa y permite acceder a la
 * pantalla de configuracion para modificar dominios, credenciales y endpoints.
 */
public class MainActivity extends AppCompatActivity {

    private TextView tvStatus;
    private TextView tvConfigSummary;

    @Override
    protected void onCreate(Bundle savedInstanceState) {
        super.onCreate(savedInstanceState);
        setContentView(R.layout.activity_main);

        tvStatus = findViewById(R.id.tv_status);
        tvConfigSummary = findViewById(R.id.tv_config_summary);
        Button btnOpenConfig = findViewById(R.id.btn_open_config);
        Button btnTestConnection = findViewById(R.id.btn_test_connection);

        btnOpenConfig.setOnClickListener(v -> {
            Intent intent = new Intent(this, RemoteConfigActivity.class);
            startActivity(intent);
        });

        btnTestConnection.setOnClickListener(v -> testConnection());

        updateConfigSummary();
    }

    @Override
    protected void onResume() {
        super.onResume();
        updateConfigSummary();
    }

    private void updateConfigSummary() {
        RemoteConfigManager config = RemoteConfigManager.getInstance();

        StringBuilder sb = new StringBuilder();
        sb.append("Region activa: ").append(config.getActiveRegion()).append("\n\n");

        sb.append("--- API OrionBase ---\n");
        sb.append("Server: ").append(config.getServerDomain()).append("\n\n");

        sb.append("--- Telemetria BI ---\n");
        sb.append("BI: ").append(config.getBiDomain()).append("\n\n");

        sb.append("--- AI Open ---\n");
        sb.append("Auth: ").append(config.getAiOpenUrl()).append("\n\n");

        sb.append("--- Credenciales ---\n");
        sb.append("App ID: ").append(config.getAppId()).append("\n");
        sb.append("Client ID: ").append(config.getClientId()).append("\n\n");

        sb.append("--- Portal AgentPOI ---\n");
        sb.append("URL: ").append(config.getAgentPoiUrl()).append("\n\n");

        sb.append("--- MQTT ---\n");
        String mqtt = config.getMqttBrokerUrl();
        sb.append("Broker: ").append(mqtt.isEmpty() ? "(no configurado)" : mqtt).append("\n");
        sb.append("Topic root: ").append(config.getMqttTopicRoot()).append("\n\n");

        sb.append("--- Endpoints Activos ---\n");
        sb.append("Apps: ").append(config.getAppsPageUrl()).append("\n");
        sb.append("Version: ").append(config.getAppsVersionUrl()).append("\n");
        sb.append("Crash: ").append(config.getCrashUploadUrl()).append("\n");
        sb.append("Token: ").append(config.getTokenUrl()).append("\n");

        tvConfigSummary.setText(sb.toString());

        boolean hasCustom = config.hasCustomConfig();
        tvStatus.setText(hasCustom ? "Configuracion personalizada activa" : "Usando valores por defecto de OrionStar");
    }

    private void testConnection() {
        RemoteConfigManager config = RemoteConfigManager.getInstance();
        String testUrl = config.getAppsVersionUrl();

        tvStatus.setText("Probando conexion a: " + testUrl + " ...");

        new Thread(() -> {
            try {
                java.net.URL url = new java.net.URL(testUrl);
                java.net.HttpURLConnection conn = (java.net.HttpURLConnection) url.openConnection();
                conn.setRequestMethod("GET");
                conn.setConnectTimeout(10000);
                conn.setReadTimeout(10000);
                int responseCode = conn.getResponseCode();
                conn.disconnect();

                runOnUiThread(() ->
                        tvStatus.setText("Respuesta de " + config.getActiveRegion()
                                + ": HTTP " + responseCode));
            } catch (Exception e) {
                runOnUiThread(() ->
                        tvStatus.setText("Error de conexion: " + e.getMessage()));
            }
        }).start();
    }
}
